{
  "expectation_suite_name": "silver_orders_suite",
  "meta": {
    "great_expectations_version": "0.18.x",
    "layer": "silver",
    "table": "orders",
    "description": "Quality checks for the Silver orders table. Validates schema presence, null constraints, allowed status values, non-negative totals, primary key uniqueness, and minimum row count."
  },
  "expectations": [
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "id" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "user_id" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "status" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "subtotal" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "tax" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "total" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "created_at" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "id" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "user_id" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "status" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "total" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "created_at" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "status",
        "value_set": ["confirmed", "shipped", "delivered", "cancelled"]
      },
      "meta": {
        "notes": "Any status outside this set indicates corrupt or unprocessed data from Bronze."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "total",
        "min_value": 0,
        "max_value": null
      },
      "meta": {
        "notes": "Order totals must be non-negative. No upper bound enforced."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": { "column": "id" },
      "meta": {
        "notes": "Primary key — deduplication in the Bronze-to-Silver job should guarantee uniqueness."
      }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 1,
        "max_value": null
      },
      "meta": {
        "notes": "An empty Silver partition indicates the extraction or ETL job failed silently."
      }
    }
  ]
}
